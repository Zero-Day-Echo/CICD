# 本地试跑 release.sh 时复制为 .env 并 source，或 export 到环境变量

# 跳过 OSS（仅本地 docker build + export）
# SKIP_UPLOAD=1

# 阿里云 OSS（upload_oss.sh 必填，除非 SKIP_UPLOAD=1）
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-bucket
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# 对象前缀，最终路径: {OSS_PREFIX}/{project}/{version}/{project}-{version}.tar.gz
OSS_PREFIX=aiexam/docker-images
